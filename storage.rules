rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Báo cáo kiểm kê gộp theo tháng — upload từ web (user đã đăng nhập)
    match /stock-check-reports/{factory}/{path=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // File Excel thô SXXK (NHAP, XUAT, TONDAU, BCTK)
    match /sxxk-raw/{year}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Bài kiểm tra đào tạo kho — PDF lưu từ web (user đã đăng nhập)
    match /warehouse-training-quiz/{path=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
